{
  "version": 2,
  "builds": [
    {
      "src": "claude.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/claude",
      "dest": "/claude.js"
    },
    {
      "src": "/app.html",
      "dest": "/app.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
